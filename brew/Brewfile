brew "node" # Installs the Node.js JavaScript runtime and npm
brew "wrk" # Installs an HTTP benchmarking tool

brew "nyancat" # Displays the animated Nyan Cat in the terminal

brew "mas" # Installs a command-line interface for the Mac App Store

cask "dotnet-sdk" # Installs the .NET SDK for building and running .NET apps
cask "visual-studio-code" # Installs Microsoft's Visual Studio Code editor

brew "azure-cli" # Installs Microsoft's Azure command-line interface

brew "kubernetes-cli" # Installs kubectl for managing Kubernetes clusters
brew "kubectx" # Switches quickly between Kubernetes contexts and namespaces
brew "kubelogin" # Provides authentication helpers for Kubernetes clusters
brew "kind" # Runs local Kubernetes clusters in Docker containers
brew "helm" # Installs the Kubernetes package manager
brew "helmfile" # Manages declarative Helm chart releases
brew "k9s" # Provides a terminal UI for managing Kubernetes clusters

