brew "tree" # Displays directory structures as a tree
brew "watch" # Runs a command repeatedly and shows updated output
brew "trash" # Moves files to the macOS Trash from the command line
brew "openssl" # Provides TLS and cryptography libraries and tools
brew "telnet" # Provides the Telnet client for testing raw TCP connections

brew "vim" # Installs the Vim terminal text editor
brew "curl" # Transfers data with URLs from the command line
brew "wget" # Downloads files from HTTP, HTTPS, and FTP sources
brew "git" # Provides distributed version control
brew "git-delta" # Installs Delta, a syntax-highlighting pager for Git and diff output
brew "fish" # Installs the Fish interactive shell
brew "fisher" # Installs a plugin manager for the Fish shell
brew "jq" # Parses and transforms JSON from the command line

brew "starship" # Provides a fast, customizable cross-shell prompt
cask "font-caskaydia-mono-nerd-font" # Installs Caskaydia Mono Nerd Font with developer icons
cask "font-jetbrains-mono-nerd-font" # Installs JetBrains Mono Nerd Font with developer icons
cask "font-fira-code-nerd-font" # Installs Fira Code Nerd Font with developer icons

